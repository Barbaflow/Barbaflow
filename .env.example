# =============================================================================
# BarbaFlow Pro — Exemplo de variáveis de ambiente
# Copie este arquivo para .env (e .env.development / .env.production) e preencha
# com os valores reais. NUNCA faça commit dos arquivos .env com valores reais.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Vite) — expostas no bundle do navegador, use apenas chaves públicas
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
# Token público do Paddle (client-side). Prefixo "test_" ativa o modo sandbox.
VITE_PAYMENTS_CLIENT_TOKEN=

# -----------------------------------------------------------------------------
# Servidor / SSR (TanStack Start em Cloudflare Workers) — process.env
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
# Chave de service role — bypassa RLS. NUNCA exponha no frontend.
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Supabase Edge Functions (Deno) — definidas como secrets no Supabase, NÃO no .env
# `supabase secrets set NOME=valor`. SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY são
# injetadas automaticamente pelo runtime das functions.
# =============================================================================
PADDLE_SANDBOX_API_KEY=
PADDLE_LIVE_API_KEY=
PAYMENTS_SANDBOX_WEBHOOK_SECRET=
PAYMENTS_LIVE_WEBHOOK_SECRET=
LOVABLE_API_KEY=
